{
  "name": "wnpm",
  "version": "0.1.0",
  "description": "A trust layer that checks npm packages before they execute.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "bin": {
    "warden": "./src/bin/warden.ts",
    "wnpm": "./src/bin/wnpm.ts",
    "wnpx": "./src/bin/wnpx.ts"
  },
  "scripts": {
    "build": "bun build ./src/bin/warden.ts --compile --outfile dist/warden && bun build ./src/bin/wnpm.ts --compile --outfile dist/wnpm && bun build ./src/bin/wnpx.ts --compile --outfile dist/wnpx",
    "strip-comments": "bun scripts/strip-comments.mjs",
    "check-comments": "bun scripts/strip-comments.mjs --check",
    "format": "biome format --write .",
    "lint": "biome check --error-on-warnings .",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "acorn": "^8.14.0",
    "acorn-walk": "^8.3.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
